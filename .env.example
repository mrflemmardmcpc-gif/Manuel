# Example .env file for local development
# Copy this file to .env and fill the values. NEVER commit your real .env to Git.

# Upstash Redis REST (used by export script for Admin live data)
UPSTASH_REDIS_REST_URL=https://<your-upstash-redis-rest-url>
UPSTASH_REDIS_REST_TOKEN=<your-upstash-rest-token>
REDIS_KEY=carnet-data

# KV store (used by /api/state) - optional if you use the same Upstash KV
KV_REST_API_URL=https://<your-kv-rest-url>
KV_REST_API_TOKEN=<your-kv-rest-token>

# GitHub - token used by /api/publish to dispatch the workflow
# Create a Personal Access Token with 'repo' and 'workflow' scopes, or use a GitHub App token.
GITHUB_TOKEN=<your-github-token>
GITHUB_OWNER=<github-owner-or-org>
GITHUB_REPO=<repo-name>
WORKFLOW_ID=export-redis-to-git.yml
WORKFLOW_REF=main

# (Optional) PAT used by CI to push commits if required. Better use repository secrets in Actions.
PAT=<personal-access-token-optional>

# Server admin key used to protect the `POST /api/export-push` endpoint
ADMIN_KEY=<choose-a-secret-string>

# Vercel token (optional) if you want to call Vercel API directly
VERCEL_TOKEN=<your-vercel-token-optional>

# --- How to obtain keys / quick steps ---
# Upstash (Redis/KV): https://upstash.com - create a Redis database, copy REST URL and REST token
# GitHub token: Settings → Developer settings → Personal access tokens → Generate new token
#   - Select scopes: repo, workflow
# Add tokens to Vercel / environment variables for production (do NOT commit .env)
# On GitHub Actions, add secrets via repo Settings → Secrets → Actions (e.g. PAT, UPSTASH_REDIS_REST_TOKEN)
